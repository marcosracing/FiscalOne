# FiscalOne — ponte técnica fiscal (ADR-0035)
# Sem banco próprio. Toda persistência é responsabilidade da vertical.

FISCAL_PROVIDER=sefaz
FISCALONE_AMBIENTE=producao

# Certificado digital — em trânsito, nunca em repouso no FiscalOne
# A vertical envia credencial temporária a cada chamada
GOV_CERT_PATH=
GOV_CERT_PASSWORD=

# FocusNFe (alternativa ao SefazProvider)
FOCUSNFE_TOKEN=
FOCUSNFE_BASE_URL=https://api.focusnfe.com.br/v2
FOCUSNFE_HOMOLOGACAO=false
