# Provider ativo: sefaz | focusnfe
FISCAL_PROVIDER=sefaz

# Provider SEFAZ
GOV_CERT_PATH=/path/to/cert.pfx
GOV_CERT_PASSWORD=senha_do_certificado

# Provider Focus NF-e
FOCUSNFE_TOKEN=seu_token_aqui
FOCUSNFE_BASE_URL=https://api.focusnfe.com.br/v2
FOCUSNFE_HOMOLOGACAO=false

# Database (ATP ou PG — ADR-0006)
DATABASE_URL=oracle+oracledb://user:pass@host/service
