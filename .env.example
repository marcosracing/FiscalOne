# FiscalOne — ponte técnica fiscal (ADR-0035)
# Sem banco próprio. Toda persistência é responsabilidade da vertical.

FISCAL_PROVIDER=sefaz
FISCALONE_AMBIENTE=homologacao

# ── PRODUCAO — LIBERADA APENAS PARA DFe RECEBIDO ──────────────────────────
# As TRES flags precisam estar em "1" para permitir producao real na SEFAZ:
#   1) FISCALONE_ENABLE_PRODUCAO   — liberacao geral do FiscalOne em producao
#   2) MAPONE_FISCAL_PRODUCAO_READY — MapOne testado e preparado para receber
#   3) FISCALONE_DFE_RECEBIDO_ONLY  — reafirma o escopo restrito (recepcao DFe)
# Emissao/cancelamento/inutilizacao/CC-e/MDF-e permanecem BLOQUEADOS por
# design, mesmo com as tres flags ligadas (guard central bloquear_emissao).
FISCALONE_ENABLE_PRODUCAO=0
MAPONE_FISCAL_PRODUCAO_READY=0
FISCALONE_DFE_RECEBIDO_ONLY=0

# ── Certificado digital A1 ────────────────────────────────────────────────
# Padrao PRODUCAO: a vertical envia cert_pfx_base64 + cert_password em cada
# chamada POST /fiscal/gov/fetch. O FiscalOne descarta ao fim da requisicao
# (chmod 600 no PEM temporario, unlink em finally).
#
# Fallback local para teste controlado — priorizado nesta ordem:
#   1) FISCALONE_CERT_PFX_BASE64 + FISCALONE_CERT_PASSWORD (PFX inline)
#   2) FISCALONE_CERT_PFX_PATH   + FISCALONE_CERT_PASSWORD (caminho)
#   3) GOV_CERT_PATH             + GOV_CERT_PASSWORD       (compat legado)
# NUNCA logar senha nem base64. Ideal: cofre definitivo (pendencia).
FISCALONE_CERT_PFX_BASE64=
FISCALONE_CERT_PFX_PATH=
FISCALONE_CERT_PASSWORD=

# Compat legado (aceito enquanto FISCALONE_CERT_* nao estiverem populados)
GOV_CERT_PATH=
GOV_CERT_PASSWORD=

# TLS insecure — SOMENTE debug local (nunca producao). "1" desabilita verificacao.
GOV_TLS_INSECURE=

# FocusNFe (alternativa ao SefazProvider — stub)
FOCUSNFE_TOKEN=
FOCUSNFE_BASE_URL=https://api.focusnfe.com.br/v2
FOCUSNFE_HOMOLOGACAO=false
