# FiscalOne — ponte técnica fiscal (ADR-0035)
# Sem banco próprio. Toda persistência é responsabilidade da vertical.

FISCAL_PROVIDER=sefaz
FISCALONE_AMBIENTE=homologacao

# PRODUCAO BLOQUEADA POR PADRAO:
# liberar somente apos MapOne estar exaustivamente testado e revisado.
FISCALONE_ENABLE_PRODUCAO=false
MAPONE_FISCAL_PRODUCAO_READY=false

# Certificado digital A1 — em trânsito, nunca em repouso no FiscalOne
# Padrao PRODUCAO: a vertical envia cert_pfx_base64 + cert_password em cada
# chamada POST /fiscal/gov/fetch. O FiscalOne descarta ao fim da requisicao.
# Fallback HOMOLOGACAO local: GOV_CERT_PATH/GOV_CERT_PASSWORD apenas para testes.
GOV_CERT_PATH=
GOV_CERT_PASSWORD=

# TLS insecure — SOMENTE debug local (nunca producao). "1" desabilita verificacao.
GOV_TLS_INSECURE=

# FocusNFe (alternativa ao SefazProvider)
FOCUSNFE_TOKEN=
FOCUSNFE_BASE_URL=https://api.focusnfe.com.br/v2
FOCUSNFE_HOMOLOGACAO=false
